# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf

# JSON/Config
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Text files
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
