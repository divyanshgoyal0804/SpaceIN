generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id           String          @id @default(cuid())
  title        String
  slug         String          @unique
  description  String
  type         PropertyType
  listingType  ListingType
  price        Float?
  rentPerMonth Float?
  carpetArea   Float
  superArea    Float?
  floor        Int?
  totalFloors  Int?
  location     String
  city         String          @default("Noida")
  latitude     Float?
  longitude    Float?
  amenities    String[]
  furnished    FurnishedType
  possession   String?
  facing       String?
  parking      Int?
  washrooms    Int?
  mainImageUrl String
  videoUrl     String?
  isFeatured   Boolean         @default(false)
  isExclusive  Boolean         @default(false)
  isActive     Boolean         @default(true)
  isSimulated  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  images       PropertyImage[]
  inquiries    Inquiry[]

  // MED-6: Indexes for frequently queried fields
  @@index([isActive, isFeatured])
  @@index([isActive, type])
  @@index([isActive, city])
  @@index([isActive, listingType])
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  caption    String?
  order      Int      @default(0)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  tags        String[]
  author      String    @default("SpaceIn Team")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Inquiry {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String
  message    String
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([createdAt])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  company     String?
  quote       String
  avatarUrl   String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum PropertyType {
  OFFICE
  COWORKING
  RETAIL
  WAREHOUSE
  SHOWROOM
  PLOT
}

enum ListingType {
  SALE
  RENT
  BOTH
}

enum FurnishedType {
  FURNISHED
  SEMI_FURNISHED
  BARE_SHELL
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  hash         String   @unique
  url          String
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())
}

// ─── Intelligent Chatbot Memory System ─────────────────────────────

model ChatUser {
  id                 String        @id @default(cuid())
  anonymousId        String        @unique
  preferredCity      String?
  budgetMin          Float?
  budgetMax          Float?
  preferredTypes     String[]      // PropertyType enum values
  preferredLocations String[]      // sectors/areas
  preferredAmenities String[]
  preferredFurnished String?       // FurnishedType enum value
  conversationCount  Int           @default(0)
  lastActiveAt       DateTime      @default(now())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  events             ChatEvent[]
  sessions           ChatSession[]
}

model ChatEvent {
  id         String   @id @default(cuid())
  userId     String
  user       ChatUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String?
  type       String   // QUERY, INTENT_EXTRACTED, RECOMMENDATION, CLICK, CONTACT, SESSION_START, SESSION_END
  payload    Json     // structured event data
  propertyId String?
  createdAt  DateTime @default(now())

  @@index([userId, type])
  @@index([propertyId])
  @@index([createdAt])
}

model ChatSession {
  id         String   @id @default(cuid())
  userId     String
  user       ChatUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary    String?  // LLM-generated summary after session ends
  intentData Json?    // last extracted intent
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

