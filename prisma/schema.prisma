generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String         @db.Text
  type          PropertyType
  listingType   ListingType
  price         Float?
  rentPerMonth  Float?
  carpetArea    Float
  superArea     Float?
  floor         Int?
  totalFloors   Int?
  location      String
  city          String         @default("Noida")
  latitude      Float?
  longitude     Float?
  amenities     String[]
  furnished     FurnishedType
  possession    String?
  facing        String?
  parking       Int?
  washrooms     Int?
  mainImageUrl  String
  images        PropertyImage[]
  isFeatured    Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  caption    String?
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  tags        String[]
  author      String    @default("SpaceIn Team")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Inquiry {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  message    String
  propertyId String?
  createdAt  DateTime @default(now())
}

enum PropertyType {
  OFFICE
  COWORKING
  RETAIL
  WAREHOUSE
  SHOWROOM
  PLOT
}

enum ListingType {
  SALE
  RENT
  BOTH
}

enum FurnishedType {
  FURNISHED
  SEMI_FURNISHED
  BARE_SHELL
}
